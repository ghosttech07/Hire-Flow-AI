# Application & Security
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Secret Keys
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_HOURS=24
JWT_REFRESH_EXPIRES_DAYS=30

# External API Keys
GEMINI_API_KEY=your_gemini_api_key_here
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev
GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Database & Cache URIs
MONGO_URI=mongodb://localhost:27017/hireflow
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
RATELIMIT_STORAGE_URI=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=1

# Thresholds
HIRE_THRESHOLD=80
SCREENING_THRESHOLD=60
